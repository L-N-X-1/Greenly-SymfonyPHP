{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
<div class="g-auth-wrap">
    <div class="g-auth-card">
        <div class="g-auth-logo">
            <div class="g-logo-icon" style="width:52px;height:52px;font-size:26px;">🌿</div>
        </div>
        <h3>Nouveau mot de passe</h3>

        {{ include('includes/flashes.twig') }}

        {{ form_start(reset_user_password) }}
            <div class="mb-3">
                <label class="form-label">Nouveau mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--g-50);border-color:var(--g-border);border-right:none;">
                        <i class="fas fa-lock" style="color:var(--g-primary);"></i>
                    </span>
                    {{ form_widget(reset_user_password.password.first, {'attr': {'class': 'form-control', 'style': 'border-left:none;padding-left:8px !important;'}}) }}
                </div>
                {% if form_errors(reset_user_password.password) is not empty %}
                    <div class="alert alert-danger mt-1 py-1 px-2" style="font-size:.8rem;">{{ form_errors(reset_user_password.password) }}</div>
                {% endif %}
            </div>
            <div class="mb-3">
                <label class="form-label">Confirmer le mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--g-50);border-color:var(--g-border);border-right:none;">
                        <i class="fas fa-lock" style="color:var(--g-primary);"></i>
                    </span>
                    {{ form_widget(reset_user_password.password.second, {'attr': {'class': 'form-control', 'style': 'border-left:none;padding-left:8px !important;'}}) }}
                </div>
            </div>
            <div class="mb-4">
                {{ form_row(reset_user_password.recaptcha) }}
            </div>
            <button type="submit" class="btn btn-green w-100 py-2">Réinitialiser</button>
        {{ form_end(reset_user_password) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script src="{{ asset('assets/js/crud.js') }}"></script>
{% endblock %}
