{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="g-auth-wrap">
    <div class="g-auth-card">
        <div class="g-auth-logo">
            <div class="g-logo-icon" style="width:52px;height:52px;font-size:26px;">🌿</div>
        </div>
        <h3>Mot de passe oublié</h3>
        <p class="text-center mb-4" style="color:var(--g-text-muted);font-size:.875rem;">
            Entrez votre email pour recevoir un lien de réinitialisation.
        </p>

        {{ include('includes/flashes.twig') }}

        {{ form_start(forgotPassword_form) }}
            <div class="mb-3">
                <label class="form-label">Adresse email</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--g-50);border-color:var(--g-border);border-right:none;">
                        <i class="fas fa-envelope" style="color:var(--g-primary);"></i>
                    </span>
                    {{ form_widget(forgotPassword_form.email, {'attr': {'class': 'form-control', 'style': 'border-left:none;padding-left:8px !important;'}}) }}
                </div>
                {% if form_errors(forgotPassword_form.email) is not empty %}
                    <div class="alert alert-danger mt-1 py-1 px-2" style="font-size:.8rem;">{{ form_errors(forgotPassword_form.email) }}</div>
                {% endif %}
            </div>
            <div class="mb-4">
                {{ form_row(forgotPassword_form.recaptcha) }}
            </div>
            <button type="submit" class="btn btn-green w-100 py-2">Envoyer le lien</button>
        {{ form_end(forgotPassword_form) }}

        <p class="text-center mt-3" style="font-size:.875rem;">
            <a href="{{ path('app_login') }}" style="color:var(--g-text-muted);">← Retour à la connexion</a>
        </p>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script src="{{ asset('assets/js/crud.js') }}"></script>
{% endblock %}
