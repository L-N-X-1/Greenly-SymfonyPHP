{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="g-auth-wrap">
    <div class="g-auth-card">
        <div class="g-auth-logo">
            <div class="g-logo-icon" style="width:52px;height:52px;font-size:26px;">🌿</div>
        </div>
        <h3>Connexion</h3>

        {{ include('includes/flashes.twig') }}

        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form id="form_login" action="{{ path('app_login') }}" method="post">
            <div class="mb-3">
                <label for="email" class="form-label">Adresse email</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--g-50);border-color:var(--g-border);border-right:none;">
                        <i class="fas fa-envelope" style="color:var(--g-primary);"></i>
                    </span>
                    <input type="email" id="email" class="form-control" style="border-left:none;padding-left:8px !important;"
                           placeholder="votre@email.com" name="_email" value="{{ last_username }}" required>
                </div>
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">Mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--g-50);border-color:var(--g-border);border-right:none;">
                        <i class="fas fa-lock" style="color:var(--g-primary);"></i>
                    </span>
                    <input type="password" id="password" name="_password" class="form-control"
                           style="border-left:none;padding-left:8px !important;" placeholder="••••••••" required>
                </div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn btn-green w-100 py-2">Se connecter</button>
        </form>

        <div class="g-divider mt-4">ou</div>

        <p class="text-center mb-1" style="font-size:.875rem;">
            Pas encore de compte ?
            <a href="{{ path('app_register') }}" style="color:var(--g-primary);font-weight:600;">Inscrivez-vous</a>
        </p>
        <p class="text-center" style="font-size:.875rem;">
            <a href="{{ path('app_forgot_password') }}" style="color:var(--g-text-muted);">Mot de passe oublié ?</a>
        </p>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('assets/js/crud.js') }}"></script>
{% endblock %}
