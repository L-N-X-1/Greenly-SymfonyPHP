{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="g-auth-wrap" style="padding:32px 16px;">
    <div class="g-auth-card" style="max-width:500px;">
        <div class="g-auth-logo">
            <div class="g-logo-icon" style="width:52px;height:52px;font-size:26px;">🌿</div>
        </div>
        <h3>Créer un compte</h3>

        {{ include('includes/flashes.twig') }}

        {{ form_start(form) }}
            <div class="mb-3">
                <label class="form-label">Nom complet</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--g-50);border-color:var(--g-border);border-right:none;">
                        <i class="fas fa-user" style="color:var(--g-primary);"></i>
                    </span>
                    {{ form_widget(form.fullName, {'attr': {'class': 'form-control', 'style': 'border-left:none;padding-left:8px !important;'}}) }}
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Adresse email</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--g-50);border-color:var(--g-border);border-right:none;">
                        <i class="fas fa-envelope" style="color:var(--g-primary);"></i>
                    </span>
                    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'style': 'border-left:none;padding-left:8px !important;'}}) }}
                </div>
                {% if form_errors(form.email) is not empty %}
                    <div class="alert alert-danger mt-1 py-1 px-2" style="font-size:.8rem;">{{ form_errors(form.email) }}</div>
                {% endif %}
            </div>

            <div class="mb-3">
                <label class="form-label">Rôle</label>
                {{ form_widget(form.roles, {'attr': {'class': 'form-select'}}) }}
                {% if form_errors(form.roles) is not empty %}
                    <div class="alert alert-danger mt-1 py-1 px-2" style="font-size:.8rem;">{{ form_errors(form.roles) }}</div>
                {% endif %}
            </div>

            <div id="verifedForm" class="mb-3" style="display:none;">
                <label class="form-label">ID Formateur</label>
                {{ form_widget(form.verifedForm, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div id="verifedEntreprise" class="mb-3" style="display:none;">
                <label class="form-label">ID Entreprise</label>
                {{ form_widget(form.verifedEntreprise, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div id="verifedAssoc" class="mb-3" style="display:none;">
                <label class="form-label">ID Association</label>
                {{ form_widget(form.verifedAssoc, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div id="verifedDonne" class="mb-3" style="display:none;">
                <label class="form-label">ID Donneur</label>
                {{ form_widget(form.verifedDonne, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="mb-3">
                <label class="form-label">Mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--g-50);border-color:var(--g-border);border-right:none;">
                        <i class="fas fa-lock" style="color:var(--g-primary);"></i>
                    </span>
                    {{ form_widget(form.password.first, {'attr': {'class': 'form-control', 'style': 'border-left:none;padding-left:8px !important;'}}) }}
                </div>
                {% if form_errors(form.password) is not empty %}
                    <div class="alert alert-danger mt-1 py-1 px-2" style="font-size:.8rem;">{{ form_errors(form.password) }}</div>
                {% endif %}
            </div>

            <div class="mb-3">
                <label class="form-label">Confirmer le mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:var(--g-50);border-color:var(--g-border);border-right:none;">
                        <i class="fas fa-lock" style="color:var(--g-primary);"></i>
                    </span>
                    {{ form_widget(form.password.second, {'attr': {'class': 'form-control', 'style': 'border-left:none;padding-left:8px !important;'}}) }}
                </div>
            </div>



            <button type="submit" class="btn btn-green w-100 py-2">S'inscrire</button>
        {{ form_end(form) }}

        <p class="text-center mt-3" style="font-size:.875rem;">
            Déjà un compte ?
            <a href="{{ path('app_login') }}" style="color:var(--g-primary);font-weight:600;">Se connecter</a>
        </p>
    </div>
</div>
{% endblock %}

{% block javascripts %}

<script src="{{ asset('assets/js/crud.js') }}"></script>
{% endblock %}
