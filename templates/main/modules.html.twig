{% extends 'base.html.twig' %}

{% block title %}Nos Modules de Formation{% endblock %}

{% block body %}
    <section class="g-hero">
        <img src="{{ asset('images/accueil.png') }}" alt="Modules" class="g-hero-bg">
        <div class="g-hero-content">
            <h1>Nos Modules de Formation</h1>
            <p>Découvrez nos programmes d'apprentissage thématiques et suivez vos progrès.</p>
        </div>
    </section>

    <div class="g-section">
        <div class="row justify-content-center mb-4">
            <div class="col-md-8">
                <div class="input-group">
                    <span class="input-group-text" style="background: var(--g-surface); border-color: var(--g-border); border-right: none;">
                        <i class="fas fa-search" style="color: var(--g-primary);"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control" style="border-left: none; padding-left: 8px !important;" placeholder="Rechercher un module...">
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <p class="mb-0 text-muted" style="font-weight: 500;">
                Nombre de modules disponibles : <span id="moduleCount" style="color: var(--g-primary); font-weight: 700;">{{ modules|length }}</span>
            </p>
        </div>

        <div class="row justify-content-center g-4" id="moduleContainer">
            {% for module in modules %}
                <div class="col-md-6 col-lg-4 module-card">
                    <div class="g-card h-100 d-flex flex-column">
                        <div class="g-card-body d-flex flex-column flex-grow-1">
                            <h4 style="font-weight: 700; color: var(--g-primary); margin-bottom: 12px;">{{ module.nomModule }}</h4>
                            <p style="font-size: 0.9rem; color: var(--g-text-muted); line-height: 1.5; margin-bottom: 16px;" class="flex-grow-1">
                                {{ module.descriptionModule|slice(0, 100) }}...
                            </p>
                            
                            <div class="mb-2" style="font-size: 0.88rem; color: var(--g-text);">
                                <strong>📅 Durée :</strong> {{ module.NbHeures }} heures
                            </div>
                            
                            <div class="mb-3" style="font-size: 0.88rem; color: var(--g-text);">
                                <strong>📌 Formations incluses :</strong> {{ module.formations|length }}
                            </div>

                            <div class="mt-auto">
                                <a href="{{ path('module_details', { id: module.id }) }}" class="g-btn g-btn-outline w-100">
                                    Voir plus <i class="fas fa-chevron-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Aucun module disponible.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    <script>
    document.getElementById('searchInput').addEventListener('input', function() {
        let query = this.value.trim();

        fetch(`/api/modules/search?q=${query}`)
            .then(response => response.json())
            .then(modules => {
                let container = document.getElementById('moduleContainer');
                container.innerHTML = ''; 

                if (modules.length === 0) {
                    container.innerHTML = '<div class="col-12 text-center py-5"><p class="text-muted">Aucun module trouvé.</p></div>';
                    document.getElementById('moduleCount').textContent = 0;
                    return;
                }

                modules.forEach(module => {
                    let card = `
                        <div class="col-md-6 col-lg-4 module-card">
                            <div class="g-card h-100 d-flex flex-column">
                                <div class="g-card-body d-flex flex-column flex-grow-1">
                                    <h4 style="font-weight: 700; color: var(--g-primary); margin-bottom: 12px;">${module.nomModule}</h4>
                                    <p style="font-size: 0.9rem; color: var(--g-text-muted); line-height: 1.5; margin-bottom: 16px;" class="flex-grow-1">
                                        ${module.descriptionModule.slice(0, 100)}...
                                    </p>
                                    <div class="mb-2" style="font-size: 0.88rem; color: var(--g-text);">
                                        <strong>📅 Durée :</strong> ${module.NbHeures} heures
                                    </div>
                                    <div class="mb-3" style="font-size: 0.88rem; color: var(--g-text);">
                                        <strong>📌 Formations incluses :</strong> ${module.formations.length}
                                    </div>
                                    <div class="mt-auto">
                                        <a href="/module/${module.id}" class="g-btn g-btn-outline w-100">
                                            Voir plus <i class="fas fa-chevron-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    container.innerHTML += card;
                });

                document.getElementById('moduleCount').textContent = modules.length;
            });
    });
    </script>
{% endblock %}
