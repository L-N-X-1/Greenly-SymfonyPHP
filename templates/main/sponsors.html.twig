{% extends 'base.html.twig' %}

{% block title %}Nos Sponsors{% endblock %}

{% block body %}
    <section class="g-hero">
        <img src="{{ asset('images/accueil.png') }}" alt="Sponsors" class="g-hero-bg">
        <div class="g-hero-content">
            <h1>Nos Sponsors</h1>
            <p>Découvrez et remerciez les entreprises et partenaires qui soutiennent nos initiatives environnementales.</p>
        </div>
    </section>

    <div class="g-section">
        {{ include('includes/flashes.twig') }}

        <div class="row g-4">
            {% for sponsor in sponsors %}
                <div class="col-md-6 col-lg-4">
                    <div class="g-card h-100 d-flex flex-column">
                        <div style="height: 160px; background: linear-gradient(135deg, var(--g-800), var(--g-primary)); display: flex; flex-direction: column; align-items: center; justify-content: center; color: white;">
                            <div style="font-size: 3.5rem; margin-bottom: 8px;">🤝</div>
                            <span style="font-weight: 800; font-size: 1.1rem; letter-spacing: 0.5px;">PARTENAIRE</span>
                        </div>

                        <div class="g-card-body d-flex flex-column flex-grow-1">
                            <h5 style="font-weight: 700; color: var(--g-text); margin-bottom: 16px;">{{ sponsor.sponsorName }}</h5>
                            
                            <div class="mb-2" style="font-size: 0.9rem; color: var(--g-text);">
                                <strong><i class="fas fa-hand-holding-usd me-1" style="color: var(--g-primary);"></i> Financement :</strong> 
                                <span class="text-success" style="font-weight: 700;">{{ sponsor.montant }} TND</span>
                            </div>

                            <div class="mb-3" style="font-size: 0.9rem; color: var(--g-text);">
                                <strong><i class="fas fa-envelope me-1" style="color: var(--g-primary);"></i> Email :</strong> 
                                <a href="mailto:{{ sponsor.email }}" style="color: var(--g-text-muted);">{{ sponsor.email }}</a>
                            </div>

                            {% if sponsor.event is not null %}
                                <div class="mt-auto p-2" style="background: var(--g-50); border-radius: var(--g-radius-sm); font-size: 0.82rem; color: var(--g-700);">
                                    <i class="fas fa-calendar-check me-1" style="color: var(--g-primary);"></i>
                                    <strong>Événement soutenu :</strong> {{ sponsor.event.eventName }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <div class="fs-1 mb-3">🤝</div>
                    <h4 style="color: var(--g-text);">Aucun sponsor</h4>
                    <p class="text-muted">Aucun sponsor enregistré pour le moment. Intéressé par un partenariat ? Contactez-nous !</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}