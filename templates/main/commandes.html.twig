{% extends 'base.html.twig' %}

{% block title %}Suivi de Commandes — Greenly{% endblock %}

{% block body %}
    <section class="g-hero">
        <img src="{{ asset('images/accueil.png') }}" alt="Suivi de Commandes" class="g-hero-bg">
        <div class="g-hero-content">
            <h1>Suivi de Commandes</h1>
            <p>Visualisez l'historique et le statut de vos commandes de produits éco-responsables.</p>
        </div>
    </section>

    <div class="g-section">
        {{ include('includes/flashes.twig') }}

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 style="font-weight: 800; color: var(--g-text); margin-bottom: 0;">Historique des Commandes</h4>
            <a href="{{ path('commande_index') }}" class="g-btn g-btn-primary">
                <i class="fas fa-plus me-1"></i> Nouvelle Commande
            </a>
        </div>

        <div class="table-responsive" style="background: var(--g-surface); border: 1px solid var(--g-border); border-radius: var(--g-radius); box-shadow: var(--g-shadow-sm); overflow: hidden; padding: 12px;">
            <table class="table table-hover align-middle mb-0" style="background: transparent;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--g-border);">
                        <th class="ps-3" style="color: var(--g-text-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase;">ID</th>
                        <th style="color: var(--g-text-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase;">Produit</th>
                        <th style="color: var(--g-text-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase;">Montant</th>
                        <th style="color: var(--g-text-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase;">Téléphone</th>
                        <th style="color: var(--g-text-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase;">Date</th>
                        <th style="color: var(--g-text-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase;">Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for commande in commandes %}
                        <tr style="border-bottom: 1px solid var(--g-border);">
                            <td class="ps-3" style="font-weight: 600; color: var(--g-text);">#{{ commande.id }}</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <span style="font-size: 1.25rem; margin-right: 8px;">📦</span>
                                    <span style="font-weight: 500; color: var(--g-text);">{{ commande.produit.nom }}</span>
                                </div>
                            </td>
                            <td style="font-weight: 600; color: var(--g-primary);">{{ commande.montant }} TND</td>
                            <td style="color: var(--g-text-muted);">{{ commande.numerot ?: 'N/A' }}</td>
                            <td style="color: var(--g-text-muted);">{{ commande.date ? commande.date|date('d/m/Y') : 'N/A' }}</td>
                            <td>
                                {% set stat = commande.statut|lower %}
                                {% if stat == 'livré' %}
                                    <span class="g-badge g-badge-green"><i class="fas fa-check me-1"></i> Livré</span>
                                {% elseif stat == 'en cours' or stat == 'en traitement' %}
                                    <span class="g-badge g-badge-yellow"><i class="fas fa-truck me-1"></i> En cours</span>
                                {% else %}
                                    <span class="g-badge" style="background: var(--g-50); color: var(--g-text-muted);"><i class="fas fa-clock me-1"></i> Reçue</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <div class="fs-1 mb-2">🛒</div>
                                <p class="mb-0">Vous n'avez pas encore passé de commande.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}