{% extends 'base.html.twig' %}

{% block title %}Faire un Don — Greenly{% endblock %}

{% block body %}
    <section class="g-hero">
        <img src="{{ asset('images/accueil.png') }}" alt="Soutenir Greenly" class="g-hero-bg">
        <div class="g-hero-content">
            <h1>Soutenir Greenly</h1>
            <p>Vos dons financent directement la collecte de déchets ménagers et le recyclage citoyen.</p>
        </div>
    </section>

    <div class="g-section">
        {{ include('includes/flashes.twig') }}

        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <h2 style="font-weight: 800; color: var(--g-text); margin-bottom: 24px;">Pourquoi faire un don ?</h2>
                
                <div class="d-flex align-items-start mb-4">
                    <div style="font-size: 2rem; margin-right: 18px; color: var(--g-primary);">🌱</div>
                    <div>
                        <h5 style="font-weight: 700; color: var(--g-text);">Protection locale</h5>
                        <p style="color: var(--g-text-muted); font-size: 0.95rem; line-height: 1.5;">Nous nettoyons les plages, forêts et parcs de votre région en partenariat direct avec des associations locales.</p>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-4">
                    <div style="font-size: 2rem; margin-right: 18px; color: var(--g-primary);">♻️</div>
                    <div>
                        <h5 style="font-weight: 700; color: var(--g-text);">Économie circulaire</h5>
                        <p style="color: var(--g-text-muted); font-size: 0.95rem; line-height: 1.5;">Nous fournissons du matériel de tri et subventionnons la revente locale d'objets réparés et restaurés.</p>
                    </div>
                </div>

                <div class="d-flex align-items-start">
                    <div style="font-size: 2rem; margin-right: 18px; color: var(--g-primary);">📚</div>
                    <div>
                        <h5 style="font-weight: 700; color: var(--g-text);">Sensibilisation & École</h5>
                        <p style="color: var(--g-text-muted); font-size: 0.95rem; line-height: 1.5;">Création d'ateliers interactifs et de guides de formation gratuits pour sensibiliser dès le plus jeune âge.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="g-card" style="border-radius: var(--g-radius-lg);">
                    <div class="g-card-body" style="padding: 40px;">
                        <h3 class="text-center" style="font-weight: 800; color: var(--g-primary); margin-bottom: 28px;">Formulaire de Don</h3>
                        
                        <div id="successMessage" class="alert alert-success d-none mb-4" role="alert">
                            <i class="fas fa-check-circle me-2"></i> Merci infiniment ! Votre don a été traité avec succès.
                        </div>

                        <form id="donationForm">
                            <div class="mb-4">
                                <label class="form-label">Montant du don</label>
                                <div class="row g-2 mb-3">
                                    <div class="col-3">
                                        <button type="button" class="g-btn g-btn-outline w-100 preset-btn" data-val="10">10 TND</button>
                                    </div>
                                    <div class="col-3">
                                        <button type="button" class="g-btn g-btn-outline w-100 preset-btn" data-val="25">25 TND</button>
                                    </div>
                                    <div class="col-3">
                                        <button type="button" class="g-btn g-btn-outline w-100 preset-btn" data-val="50">50 TND</button>
                                    </div>
                                    <div class="col-3">
                                        <button type="button" class="g-btn g-btn-outline w-100 preset-btn" data-val="100">100 TND</button>
                                    </div>
                                </div>
                                <input type="number" id="customAmount" class="form-control text-center" placeholder="Autre montant (TND)" min="5" required>
                            </div>

                            <div class="mb-3">
                                <label for="donEmail" class="form-label">Adresse email</label>
                                <input type="email" id="donEmail" class="form-control" placeholder="votre@email.com" required>
                            </div>

                            <div class="mb-4">
                                <label for="donCard" class="form-label">Numéro de carte</label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background: var(--g-50); border-color: var(--g-border); border-right: none;">
                                        <i class="fas fa-credit-card" style="color: var(--g-primary);"></i>
                                    </span>
                                    <input type="text" id="donCard" class="form-control" style="border-left: none; padding-left: 8px !important;" placeholder="4000 1234 5678 9010" required>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-green w-100 py-3">
                                <i class="fas fa-heart me-1"></i> Confirmer mon don
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const presetBtns = document.querySelectorAll('.preset-btn');
            const customInput = document.getElementById('customAmount');
            const form = document.getElementById('donationForm');
            const successAlert = document.getElementById('successMessage');

            presetBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    presetBtns.forEach(b => b.classList.remove('g-btn-primary'));
                    btn.classList.add('g-btn-primary');
                    customInput.value = btn.dataset.val;
                });
            });

            customInput.addEventListener('input', () => {
                presetBtns.forEach(b => b.classList.remove('g-btn-primary'));
            });

            form.addEventListener('submit', (e) => {
                e.preventDefault();
                successAlert.classList.remove('d-none');
                form.reset();
                presetBtns.forEach(b => b.classList.remove('g-btn-primary'));
                window.scrollTo({ top: successAlert.offsetTop - 100, behavior: 'smooth' });
            });
        });
    </script>
{% endblock %}