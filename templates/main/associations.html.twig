{% extends 'base.html.twig' %}

{% block title %}Nos Associations Partenaires{% endblock %}

{% block body %}
    <section class="g-hero">
        <img src="{{ asset('images/accueil.png') }}" alt="Associations" class="g-hero-bg">
        <div class="g-hero-content">
            <h1>Associations Partenaires</h1>
            <p>Découvrez les structures et collectifs citoyens œuvrant sur le terrain pour la transition écologique.</p>
        </div>
    </section>

    <div class="g-section">
        {{ include('includes/flashes.twig') }}

        <div class="row g-4">
            {% for assoc in associations %}
                <div class="col-md-6 col-lg-4">
                    <div class="g-card h-100 d-flex flex-column">
                        <div style="height: 160px; background: linear-gradient(135deg, var(--g-50), var(--g-200)); display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--g-700);">
                            <div style="font-size: 3.5rem; margin-bottom: 8px;">🌍</div>
                            <span style="font-weight: 800; font-size: 1.1rem; letter-spacing: 0.5px;">ASSOCIATION</span>
                        </div>

                        <div class="g-card-body d-flex flex-column flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 style="font-weight: 700; color: var(--g-text); margin-bottom: 0;">
                                    {{ assoc.fullName ?: 'Association Sans Nom' }}
                                </h5>
                                
                                {% if assoc.verifedAssoc is not null and assoc.verifedAssoc|lower == 'oui' %}
                                    <span class="g-badge g-badge-green" title="Association vérifiée">
                                        <i class="fas fa-check-circle me-1"></i> Vérifiée
                                    </span>
                                {% else %}
                                    <span class="g-badge g-badge-yellow" title="En cours de vérification">
                                        En attente
                                    </span>
                                {% endif %}
                            </div>

                            <div class="mb-3" style="font-size: 0.9rem; color: var(--g-text);">
                                <strong><i class="fas fa-envelope me-1" style="color: var(--g-primary);"></i> Contact :</strong> 
                                <a href="mailto:{{ assoc.email }}" style="color: var(--g-text-muted);">{{ assoc.email }}</a>
                            </div>

                            <div class="mt-auto p-2" style="background: var(--g-50); border-radius: var(--g-radius-sm); font-size: 0.82rem; color: var(--g-text-muted);">
                                <strong>Membre depuis :</strong> {{ assoc.createdAt|date('d/m/Y') }}
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <div class="fs-1 mb-3">🌍</div>
                    <h4 style="color: var(--g-text);">Aucune association</h4>
                    <p class="text-muted">Aucune association n'est actuellement inscrite sur notre plateforme. Rejoignez-nous pour apparaître ici !</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}