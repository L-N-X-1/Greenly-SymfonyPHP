{% extends 'base.html.twig' %}

{% block title %}Nos Événements{% endblock %}

{% block body %}
    <section class="g-hero">
        <img src="{{ asset('images/accueil.png') }}" alt="Nos Événements" class="g-hero-bg">
        <div class="g-hero-content">
            <h1>Nos Événements</h1>
            <p>Engageons-nous ensemble pour un avenir plus durable à travers nos rencontres et chantiers participatifs.</p>
        </div>
    </section>

    <div class="g-section">
        {{ include('includes/flashes.twig') }}

        <div class="row g-4">
            {% for event in events %}
                <div class="col-md-6 col-lg-4">
                    <div class="g-card h-100 d-flex flex-column">
                        <div style="height: 8px; background: linear-gradient(90deg, var(--g-primary), var(--g-300));"></div>
                        <div class="g-card-body d-flex flex-column flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="mb-0" style="font-weight: 700; color: var(--g-text);">{{ event.eventName }}</h5>
                                <span class="g-badge {% if event.eventStatus|lower == 'actif' %}g-badge-green{% else %}g-badge-yellow{% endif %}">
                                    {{ event.eventStatus }}
                                </span>
                            </div>
                            
                            <div class="mb-2" style="font-size: 0.9rem; color: var(--g-primary); font-weight: 500;">
                                <i class="fas fa-calendar-alt me-2"></i>
                                {{ event.eventDate ? event.eventDate|date('d F Y à H:i') : 'Date à préciser' }}
                            </div>
                            
                            <div class="mb-3" style="font-size: 0.9rem; color: var(--g-text-muted);">
                                <i class="fas fa-map-marker-alt me-2"></i>
                                {{ event.eventLocation }}
                            </div>
                            
                            <p class="mb-4 flex-grow-1" style="font-size: 0.9rem; color: var(--g-text-muted); line-height: 1.5;">
                                {{ event.eventDescription|length > 150 ? event.eventDescription|slice(0, 150) ~ '...' : event.eventDescription }}
                            </p>
                            
                            {% if event.sponsors|length > 0 %}
                                <div class="p-2 mb-4" style="background: var(--g-50); border-radius: var(--g-radius-sm); font-size: 0.82rem; color: var(--g-700);">
                                    <i class="fas fa-handshake me-1" style="color: var(--g-primary);"></i>
                                    <strong>Sponsors :</strong>
                                    {% for sponsor in event.sponsors %}
                                        {{ sponsor.sponsorName }}{% if not loop.last %}, {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}

                            <div class="mt-auto d-flex flex-column gap-2">
                                <a href="{{ path('app_attendee_new', {'event': event.id}) }}" class="g-btn g-btn-primary w-100">
                                    <i class="fas fa-user-plus me-1"></i> Participer
                                </a>
                                <a href="{{ path('app_event_add_to_calendar', {'id': event.id}) }}" class="g-btn g-btn-outline w-100">
                                    <i class="fas fa-calendar-plus me-1"></i> Google Calendar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="p-5 text-center bg-white border rounded" style="border-radius: var(--g-radius);">
                        <div class="fs-1 mb-3">📅</div>
                        <h4 style="color: var(--g-text);">Aucun événement</h4>
                        <p class="text-muted">Aucun événement n'est disponible pour le moment. Revenez bientôt !</p>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}