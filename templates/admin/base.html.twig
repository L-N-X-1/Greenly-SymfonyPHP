<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <link rel="icon" type="image/png" href="{{ asset('assets/img/favicon.png') }}">
  <title>{% block title %}Administration{% endblock %} — Greenly Admin</title>
  {% block stylesheets %}
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
  <link href="https://cdn.jsdelivr.net/gh/creativetimofficial/material-dashboard@master/assets/css/nucleo-icons.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/gh/creativetimofficial/material-dashboard@master/assets/css/nucleo-svg.css" rel="stylesheet" />
  <script src="https://kit.fontawesome.com/42d5adcbca.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />
  <link id="pagestyle" href="https://cdn.jsdelivr.net/gh/creativetimofficial/material-dashboard@master/assets/css/material-dashboard.min.css?v=3.2.0" rel="stylesheet" />
  <link rel="stylesheet" href="{{ asset('styles.css') }}">
  {% endblock %}
</head>

<body class="g-sidenav-show bg-gray-100">

  <aside class="sidenav navbar navbar-vertical navbar-expand-xs border-radius-lg fixed-start ms-2 my-2" id="sidenav-main">
    <div class="sidenav-header">
      <i class="fas fa-times p-3 cursor-pointer opacity-5 position-absolute end-0 top-0 d-none d-xl-none"
         style="color:rgba(255,255,255,.6);" id="iconSidenav"></i>
      <a class="navbar-brand px-3 py-3 m-0" href="{{ path('admin_dashboard') }}">
        <div class="g-logo-icon-sm">🌿</div>
        <div class="ms-2">
          <span style="font-size:1rem;font-weight:800;color:white;display:block;line-height:1.2;">Greenly</span>
          <small style="font-size:.65rem;color:rgba(255,255,255,.4);font-weight:400;">Administration</small>
        </div>
      </a>
    </div>
    <hr class="horizontal dark mt-0 mb-2">

    <div class="collapse navbar-collapse w-auto" id="sidenav-collapse-main">
      <ul class="navbar-nav">

        <li class="nav-item mt-2">
          <h6 class="ps-4 ms-2 text-uppercase text-xs font-weight-bolder opacity-5">Principal</h6>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="{{ path('admin_dashboard') }}">
            <i class="material-symbols-rounded opacity-5">dashboard</i>
            <span class="nav-link-text ms-1">Dashboard</span>
          </a>
        </li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="tablesDropdown" role="button"
             data-bs-toggle="dropdown" aria-expanded="false">
            <i class="material-symbols-rounded opacity-5">table_view</i>
            <span class="nav-link-text ms-1">Gestion</span>
          </a>
          <ul class="dropdown-menu" aria-labelledby="tablesDropdown">
            <li><a class="dropdown-item" href="{{ path('app_user_index') }}">
              <i class="fas fa-users me-2 fa-sm"></i>Utilisateurs
            </a></li>
            <li><a class="dropdown-item" href="{{ path('produit_index') }}">
              <i class="fas fa-box me-2 fa-sm"></i>Produits & Commandes
            </a></li>
            <li><a class="dropdown-item" href="{{ path('admin_formations_modules') }}">
              <i class="fas fa-graduation-cap me-2 fa-sm"></i>Formations & Modules
            </a></li>
            <li><a class="dropdown-item" href="{{ path('admin_dons_associations') }}">
              <i class="fas fa-hand-holding-heart me-2 fa-sm"></i>Dons & Associations
            </a></li>
            <li><a class="dropdown-item" href="{{ path('admin_evenements_sponsors') }}">
              <i class="fas fa-calendar-alt me-2 fa-sm"></i>Événements & Sponsors
            </a></li>
          </ul>
        </li>

        <li class="nav-item mt-3">
          <h6 class="ps-4 ms-2 text-uppercase text-xs font-weight-bolder opacity-5">Compte</h6>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="{{ path('admin_notifications') }}">
            <i class="material-symbols-rounded opacity-5">notifications</i>
            <span class="nav-link-text ms-1">Notifications</span>
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="{{ path('admin_profile') }}">
            <i class="material-symbols-rounded opacity-5">person</i>
            <span class="nav-link-text ms-1">Profil</span>
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="{{ path('app_logout') }}">
            <i class="material-symbols-rounded opacity-5">logout</i>
            <span class="nav-link-text ms-1">Déconnexion</span>
          </a>
        </li>

        <li class="nav-item mt-3 mb-2">
          <hr class="horizontal" style="border-color:rgba(255,255,255,.08);">
          <a class="nav-link" href="{{ path('app_home') }}" target="_blank">
            <i class="material-symbols-rounded opacity-5">open_in_new</i>
            <span class="nav-link-text ms-1">Voir le site</span>
          </a>
        </li>

      </ul>
    </div>
  </aside>

  <div class="main-content position-relative max-height-vh-100 h-100">
    <nav class="navbar navbar-main navbar-expand-lg px-0 mx-3 shadow-none border-radius-xl navbar-main"
         id="navbarBlur" data-scroll="true">
      <div class="container-fluid py-1 px-3">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb bg-transparent mb-0 pb-0 pt-1 px-0 me-sm-6 me-5">
            <li class="breadcrumb-item text-sm">
              <a class="opacity-5 text-dark" href="{{ path('admin_dashboard') }}">Admin</a>
            </li>
            <li class="breadcrumb-item text-sm text-dark active" aria-current="page">
              {% block breadcrumb %}{% endblock %}
            </li>
          </ol>
        </nav>
        <div class="collapse navbar-collapse mt-sm-0 mt-2 me-md-0 me-sm-4" id="navbar">
          <div class="ms-md-auto pe-md-3 d-flex align-items-center">
            <div class="input-group input-group-outline">
              <label class="form-label">Rechercher...</label>
              <input type="text" class="form-control">
            </div>
          </div>
          <ul class="navbar-nav d-flex align-items-center justify-content-end">
            <li class="nav-item px-3 d-flex align-items-center">
              <a href="{{ path('admin_notifications') }}" class="nav-link text-body p-0">
                <i class="material-symbols-rounded">notifications</i>
              </a>
            </li>
            <li class="nav-item d-flex align-items-center">
              <a href="{{ path('admin_profile') }}" class="nav-link text-body font-weight-bold px-0">
                <i class="material-symbols-rounded">account_circle</i>
              </a>
            </li>
            <li class="nav-item d-xl-none ps-3 d-flex align-items-center">
              <a href="javascript:;" class="nav-link text-body p-0" id="iconNavbarSidenav">
                <div class="sidenav-toggler-inner">
                  <i class="sidenav-toggler-line"></i>
                  <i class="sidenav-toggler-line"></i>
                  <i class="sidenav-toggler-line"></i>
                </div>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    {% block body %}{% endblock %}

    <footer class="footer py-3 px-4">
      <div class="container-fluid">
        <div class="row align-items-center justify-content-between">
          <div class="col-auto">
            <span class="text-sm text-muted">
              &copy; {{ "now"|date("Y") }} <strong style="color:var(--g-primary);">Greenly</strong> — Plateforme éco-responsable
            </span>
          </div>
          <div class="col-auto">
            <a href="{{ path('app_home') }}" class="text-sm" style="color:var(--g-primary);">Voir le site public</a>
          </div>
        </div>
      </div>
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/gh/creativetimofficial/material-dashboard@master/assets/js/core/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/gh/creativetimofficial/material-dashboard@master/assets/js/core/bootstrap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/gh/creativetimofficial/material-dashboard@master/assets/js/plugins/perfect-scrollbar.min.js"></script>
  <script src="https://cdn.jsdelivr.net/gh/creativetimofficial/material-dashboard@master/assets/js/plugins/smooth-scrollbar.min.js"></script>
  <script>
    var win = navigator.platform.indexOf('Win') > -1;
    if (win && document.querySelector('#sidenav-scrollbar')) {
      Scrollbar.init(document.querySelector('#sidenav-scrollbar'), { damping: '0.5' });
    }
  </script>
  <script src="https://cdn.jsdelivr.net/gh/creativetimofficial/material-dashboard@master/assets/js/material-dashboard.min.js?v=3.2.0"></script>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="{{ asset('assets/js/crud.js') }}"></script>
  {% block javascripts %}{% endblock %}
</body>
</html>
